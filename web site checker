# ─── 1. IP & DNS LOOKUP ────────────────────────────────────
def get_ip_dns(domain):
    section("IP ADDRESS & DNS RECORDS")
    try:
        ip = socket.gethostbyname(domain)
        field("IPv4 Address", ip, G)
    except Exception as e:
        field("IPv4 Address", f"Failed — {e}", R)
        ip = None

    # All IPs
    try:
        all_ips = socket.getaddrinfo(domain, None)
        unique = list(set([r[4][0] for r in all_ips]))
        field("All Resolved IPs", ", ".join(unique), Y)
    except:
        pass

    # Reverse DNS
    try:
        reverse = socket.gethostbyaddr(ip)[0] if ip else "N/A"
        field("Reverse DNS (PTR)", reverse, C)
    except:
        field("Reverse DNS (PTR)", "Not available", DIM)

    # DNS Records via socket
    try:
        import subprocess
        for rtype in ["A", "MX", "NS", "TXT"]:
            result = subprocess.run(
                ["dig", "+short", rtype, domain],
                capture_output=True, text=True, timeout=5
            )
            out = result.stdout.strip().replace("\n", " | ")
            if out:
                field(f"DNS {rtype} Record", out[:80], Y)
            else:
                field(f"DNS {rtype} Record", "No record found", DIM)
    except FileNotFoundError:
        field("DNS Records", "dig not found — run: apt install dnsutils", R)
    except Exception as e:
        field("DNS Records", f"Error: {e}", R)

    return ip

# ─── 2. WHOIS ──────────────────────────────────────────────
def get_whois(domain):
    section("WHOIS INFORMATION")
    try:
        import subprocess
        result = subprocess.run(
            ["whois", domain],
            capture_output=True, text=True, timeout=10
        )
        output = result.stdout

        fields_to_find = {
            "Registrar"        : r"Registrar:\s*(.+)",
            "Registrant Org"   : r"Registrant Organization:\s*(.+)",
            "Registrant Country": r"Registrant Country:\s*(.+)",
            "Created Date"     : r"Creation Date:\s*(.+)",
            "Updated Date"     : r"Updated Date:\s*(.+)",
            "Expiry Date"      : r"Registry Expiry Date:\s*(.+)",
            "Name Servers"     : r"Name Server:\s*(.+)",
            "DNSSEC"           : r"DNSSEC:\s*(.+)",
            "Status"           : r"Domain Status:\s*(.+)",
        }

        found_any = False
        for label, pattern in fields_to_find.items():
            match = re.search(pattern, output, re.IGNORECASE)
            if match:
                val = match.group(1).strip()[:70]
                field(label, val, C)
                found_any = True

        if not found_any:
            print(f"  {Y}[~] WHOIS data not parseable. Raw output below:{X}")
            for line in output.splitlines()[:20]:
                if line.strip():
                    print(f"  {DIM}{line.strip()}{X}")

    except FileNotFoundError:
        print(f"  {R}[!] whois not installed. Run: apt install whois{X}")
    except Exception as e:
        print(f"  {R}[!] WHOIS Error: {e}{X}")

# ─── 3. HTTP HEADERS ───────────────────────────────────────
def get_http_headers(domain):
    section("HTTP HEADERS & SERVER INFO")
    for scheme in ["https", "http"]:
        try:
            url = f"{scheme}://{domain}"
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=8) as resp:
                code = resp.getcode()
                headers = dict(resp.headers)

                color = G if code == 200 else Y if code in [301,302] else R
                field("URL Probed", url, C)
                field("HTTP Status Code", f"{code}", color)

                interesting = [
                    "Server", "X-Powered-By", "Content-Type",
                    "X-Frame-Options", "X-XSS-Protection",
                    "Strict-Transport-Security", "Content-Security-Policy",
                    "X-Content-Type-Options", "Set-Cookie", "Location",
                    "Via", "X-Cache", "CF-Ray", "X-Amz-Cf-Id"
                ]
                for h in interesting:
                    val = headers.get(h, headers.get(h.lower(), None))
                    if val:
                        field(h, str(val)[:70], Y)

                # Security rating
                security_headers = ["Strict-Transport-Security","X-Frame-Options",
                                    "X-XSS-Protection","Content-Security-Policy",
                                    "X-Content-Type-Options"]
                present = sum(1 for h in security_headers if headers.get(h))
                rating = f"{present}/{len(security_headers)}"
                clr = G if present >= 4 else Y if present >= 2 else R
                field("Security Headers Score", rating, clr)
                return
        except urllib.error.HTTPError as e:
            field("HTTP Status", f"{e.code} {e.reason}", R)
            return
        except Exception:
            continue
    print(f"  {R}[!] Could not connect to target.{X}")

# ─── 4. SSL CERTIFICATE ────────────────────────────────────
def get_ssl_info(domain):
    section("SSL / TLS CERTIFICATE")
    try:
        ctx = ssl.create_default_context()
        with ctx.wrap_socket(socket.socket(), server_hostname=domain) as s:
            s.settimeout(8)
            s.connect((domain, 443))
            cert = s.getpeercert()

        subject = dict(x[0] for x in cert.get("subject", []))
        issuer  = dict(x[0] for x in cert.get("issuer", []))

        field("Common Name (CN)",   subject.get("commonName", "N/A"), G)
        field("Organization",       subject.get("organizationName", "N/A"), C)
        field("Issued By",          issuer.get("organizationName", "N/A"), Y)
        field("Valid From",         cert.get("notBefore", "N/A"), C)
        field("Valid Until",        cert.get("notAfter", "N/A"), C)

        # Check expiry
        try:
            exp = datetime.strptime(cert["notAfter"], "%b %d %H:%M:%S %Y %Z")
            days_left = (exp - datetime.utcnow()).days
            clr = G if days_left > 60 else Y if days_left > 14 else R
            field("Days Until Expiry", f"{days_left} days", clr)
        except:
            pass

        # SANs
        sans = cert.get("subjectAltName", [])
        san_list = [v for t, v in sans if t == "DNS"]
        if san_list:
            field("SANs (Alt Names)", ", ".join(san_list[:5]), DIM)

        field("TLS Version", s.version() if hasattr(s, 'version') else "N/A", Y)

    except ssl.SSLCertVerificationError:
        print(f"  {R}[!] SSL Certificate verification FAILED — possible MITM or expired cert{X}")
    except ConnectionRefusedError:
        print(f"  {Y}[~] Port 443 closed — no HTTPS on this target{X}")
    except Exception as e:
        print(f"  {R}[!] SSL Error: {e}{X}")

# ─── 5. PORT SCANNER ───────────────────────────────────────
def port_scan(ip):
    section("COMMON PORT SCANNER")
    if not ip:
        print(f"  {R}[!] No IP available for port scan.{X}")
        return

    ports = {
        21: "FTP", 22: "SSH", 23: "Telnet", 25: "SMTP",
        53: "DNS", 80: "HTTP", 110: "POP3", 143: "IMAP",
        443: "HTTPS", 445: "SMB", 3306: "MySQL", 3389: "RDP",
        5432: "PostgreSQL", 6379: "Redis", 8080: "HTTP-Alt",
        8443: "HTTPS-Alt", 27017: "MongoDB"
    }

    open_ports = []
    closed_ports = []

    print(f"  {Y}[>] Scanning {len(ports)} common ports on {ip}...{X}\n")

    def scan_port(port, service):
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(0.8)
            result = s.connect_ex((ip, port))
            s.close()
            if result == 0:
                open_ports.append((port, service))
            else:
                closed_ports.append((port, service))
        except:
            closed_ports.append((port, service))

    threads = []
    for port, service in ports.items():
        t = threading.Thread(target=scan_port, args=(port, service))
        threads.append(t)
        t.start()
    for t in threads:
        t.join()

    open_ports.sort()
    if open_ports:
        for port, service in open_ports:
            print(f"  {G}  [OPEN]  {X}{Y}Port {port:<6}{X}  {G}{service}{X}")
    else:
        print(f"  {Y}  [~] No common ports found open.{X}")

    print(f"\n  {DIM}Total scanned: {len(ports)} | Open: {len(open_ports)} | Closed: {len(closed_ports)}{X}")

