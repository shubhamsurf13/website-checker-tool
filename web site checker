def subdomain_scan(domain):
    section("SUBDOMAIN SCANNER")
    wordlist = [
        "www", "mail", "ftp", "admin", "blog", "dev", "test", "api",
        "shop", "store", "portal", "vpn", "remote", "staging", "app",
        "secure", "login", "dashboard", "cdn", "static", "media",
        "forum", "help", "support", "docs", "git", "m", "mobile",
        "old", "new", "beta", "cloud", "server", "ns1", "ns2",
        "smtp", "pop", "imap", "webmail", "cpanel", "whm", "host"
    ]

    found = []
    print(f"  {Y}[>] Probing {len(wordlist)} subdomains...{X}\n")

    def check_sub(sub):
        full = f"{sub}.{domain}"
        try:
            ip = socket.gethostbyname(full)
            found.append((full, ip))
            print(f"  {G}  [FOUND] {X}{C}{full:<40}{X}  {Y}{ip}{X}")
        except:
            pass

    threads = []
    for sub in wordlist:
        t = threading.Thread(target=check_sub, args=(sub,))
        threads.append(t)
        t.start()
    for t in threads:
        t.join()

    if not found:
        print(f"  {Y}  [~] No subdomains discovered from wordlist.{X}")
    print(f"\n  {DIM}Probed: {len(wordlist)} | Found: {len(found)}{X}")
    return found

# ─── 7. GEOLOCATION ────────────────────────────────────────
def get_geo(ip):
    section("IP GEOLOCATION")
    if not ip:
        print(f"  {R}[!] No IP to geolocate.{X}")
        return
    try:
        url = f"http://ip-api.com/json/{ip}?fields=status,country,regionName,city,isp,org,as,lat,lon,timezone,mobile,proxy,hosting"
        req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=6) as resp:
            data = json.loads(resp.read().decode())

        if data.get("status") == "success":
            field("Country",      data.get("country", "N/A"), G)
            field("Region",       data.get("regionName", "N/A"), C)
            field("City",         data.get("city", "N/A"), C)
            field("ISP",          data.get("isp", "N/A"), Y)
            field("Organization", data.get("org", "N/A"), Y)
            field("ASN",          data.get("as", "N/A"), DIM)
            field("Timezone",     data.get("timezone", "N/A"), C)
            field("Coordinates",  f"{data.get('lat')} , {data.get('lon')}", DIM)
            field("Proxy/VPN",    str(data.get("proxy", False)), R if data.get("proxy") else G)
            field("Hosting/DC",   str(data.get("hosting", False)), Y)
            field("Mobile IP",    str(data.get("mobile", False)), Y)
        else:
            print(f"  {R}[!] GeoIP lookup failed for {ip}{X}")
    except Exception as e:
        print(f"  {R}[!] GeoIP Error: {e}{X}")

# ─── 8. ROBOTS & SITEMAP ───────────────────────────────────
def get_robots(domain):
    section("ROBOTS.TXT & SITEMAP RECON")
    targets = [
        f"https://{domain}/robots.txt",
        f"http://{domain}/robots.txt",
    ]
    for url in targets:
        try:
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=6) as resp:
                if resp.getcode() == 200:
                    content = resp.read().decode(errors="ignore")
                    field("robots.txt Found", url, G)
                    lines = [l.strip() for l in content.splitlines() if l.strip()]
                    disallowed = [l for l in lines if l.lower().startswith("disallow")]
                    sitemaps   = [l for l in lines if l.lower().startswith("sitemap")]
                    print(f"\n  {Y}  Disallowed paths ({len(disallowed)} found):{X}")
                    for d in disallowed[:10]:
                        print(f"  {R}    {d}{X}")
                    if sitemaps:
                        print(f"\n  {Y}  Sitemaps:{X}")
                        for s in sitemaps:
                            print(f"  {G}    {s}{X}")
                    return
        except:
            continue
    print(f"  {Y}[~] robots.txt not found or inaccessible.{X}")

