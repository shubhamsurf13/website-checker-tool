                url = f"{scheme}://{domain}"
                req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
                with urllib.request.urlopen(req, timeout=8) as resp:
                    headers = dict(resp.headers)
                    body = resp.read(4096).decode(errors="ignore")
                break
            except:
                continue

        techs = []

        # Server
        server = headers.get("Server", "")
        if server: techs.append(f"Server: {server}")

        # Powered by
        xpb = headers.get("X-Powered-By", "")
        if xpb: techs.append(f"Powered By: {xpb}")

        # CMS detection
        cms_sigs = {
            "WordPress"  : ["wp-content", "wp-includes", "wp-json"],
            "Joomla"     : ["joomla", "/components/com_"],
            "Drupal"     : ["drupal", "sites/default/files"],
            "Shopify"    : ["shopify", "cdn.shopify.com"],
            "Wix"        : ["wixstatic", "wix.com"],
            "Squarespace": ["squarespace", "sqspcdn"],
            "Magento"    : ["magento", "mage/"],
            "Laravel"    : ["laravel_session"],
            "Django"     : ["csrfmiddlewaretoken", "django"],
            "React"      : ["react", "__NEXT_DATA__", "reactroot"],
            "Angular"    : ["ng-version", "ng-app"],
            "Vue.js"     : ["vue", "__vue__"],
            "jQuery"     : ["jquery"],
            "Bootstrap"  : ["bootstrap"],
            "Cloudflare" : ["cf-ray", "__cfduid", "cloudflare"],
            "AWS"        : ["x-amz", "amazonaws"],
            "Nginx"      : ["nginx"],
            "Apache"     : ["apache"],
        }

        detected = []
        body_lower = body.lower()
        headers_str = str(headers).lower()

