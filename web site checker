def slow_print(text, delay=0.018):
    for ch in text:
        print(ch, end="", flush=True)
        time.sleep(delay)
    print()

def separator(char="─", color=C, width=62):
    print(f"{color}{char * width}{X}")

def fake_scan(label, steps=20, delay=0.035):
    for i in range(steps + 1):
        filled = int((i / steps) * 20)
        bar = f"[{'█' * filled}{'░' * (20 - filled)}]"
        pct = int((i / steps) * 100)
        print(f"\r  {C}{label}{X}  {G}{bar}{X}  {Y}{pct}%{X}", end="", flush=True)
        time.sleep(delay + random.uniform(0, 0.01))
    print(f"  {G}✓{X}")

def section(title):
    print(f"\n{W}  [+] {title}{X}")
    print(f"  {DIM}{'─' * 50}{X}")

def field(label, value, color=C):
    print(f"  {color}{label:<28}{X}  {W}{value}{X}")

def clean_domain(target):
    target = target.strip()
    target = re.sub(r'^https?://', '', target)
    target = re.sub(r'^www\.', '', target)
    target = target.split('/')[0]
    return target

